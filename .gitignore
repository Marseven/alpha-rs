/node_modules
/public/hot
/public/storage
/storage/*.key
.htaccess
.env
.env.backup
.phpunit.result.cache
npm-debug.log
yarn-error.log

# Sensitive / dumped files must never be committed (esp. under public/)
*.sql
*.dump
*.bak
*.zip
*.tar
*.gz
*.sqlite
public/upload/**/*.sql
public/upload/**/*.php
public/upload/**/*.env

# but allow our protective .htaccess files to be tracked
!public/.htaccess
!public/**/.htaccess

# Documents médicaux téléversés : ne JAMAIS versionner (cf. public/upload/quote/.htaccess).
# Les nouveaux dépôts vont sur le disque privé (storage/app/private) via SensitiveFileStorage.
public/upload/quote/*
!public/upload/quote/.htaccess
