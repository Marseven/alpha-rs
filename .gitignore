/node_modules
/public/hot
/public/storage
/storage/*.key
.htaccess
.env
.env.backup
.phpunit.result.cache
docker-compose.override.yml
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log

# Sensitive / dumped files must never be committed (esp. under public/)
*.sql
*.dump
*.bak
*.zip
*.tar
*.gz
*.sqlite
public/upload/**/*.sql
public/upload/**/*.php
public/upload/**/*.env

# but allow our protective .htaccess files to be tracked
!public/.htaccess
!public/**/.htaccess

# Dependencies should not be versioned. vendor/ is still tracked for now to
# avoid breaking a git-pull deployment; see docs/DEPLOYMENT.md for the safe
# cutover (git rm -r --cached vendor once `composer install` is confirmed).
/vendor
