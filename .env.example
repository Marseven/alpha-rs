APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---------------------------------------------------------------------------
# Payment gateways — set real values in .env (NEVER commit them).
# Any value previously hardcoded in the source must be considered COMPROMISED
# and rotated with the provider before going live.
# ---------------------------------------------------------------------------

# Singpay
SINGPAY_BASE_URL=https://gateway.singpay.ga/v1/ext
SINGPAY_INQUIRY_URL=
SINGPAY_CLIENT_ID=
SINGPAY_CLIENT_SECRET=
SINGPAY_WALLET_ID=
SINGPAY_DISBURSEMENT_WALLET_ID=

# E-Billing (CGI)
EBILLING_BASE_URL=
EBILLING_INQUIRY_URL=
EBILLING_POST_URL=
EBILLING_USERNAME=
EBILLING_SHARED_KEY=

# HMAC secret used to verify incoming payment webhooks (/notify/*)
PAYMENT_WEBHOOK_SECRET=

# Flat fee (FCFA) charged for a quote/devis request
QUOTE_PAYMENT_AMOUNT=50000

# Require a server-to-server inquiry with the PSP before settling a webhook
PAYMENT_REQUIRE_PROVIDER_INQUIRY=false

# ---------------------------------------------------------------------------
# Relief Services — business config
# ---------------------------------------------------------------------------
RELIEF_CONTACT_EMAIL=
RELIEF_CONTACT_PHONE=
CASE_TRACKING_PREFIX=RS

# AI assistant (guarded Q&A). Works with any OpenAI-compatible endpoint.
# Free options (choose one, get a free key, then set the 4 vars below):
#   Groq     : AI_BASE_URL=https://api.groq.com/openai/v1            AI_MODEL=llama-3.3-70b-versatile   (console.groq.com)
#   Gemini   : AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  AI_MODEL=gemini-1.5-flash  (aistudio.google.com)
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1             AI_MODEL=meta-llama/llama-3.1-8b-instruct:free  (openrouter.ai)
# Never commit a real key.
AI_ASSISTANT_ENABLED=false
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Future notifications (not wired to a real API yet)
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
